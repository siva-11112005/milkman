<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_16">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/spacing_16">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Super User Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:text="Admin Management"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Add Admin Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add New Admin"
        android:layout_marginBottom="@dimen/spacing_16"
        app:backgroundTint="@color/brand_primary" />

    <!-- Admins List -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All Admins"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="@dimen/spacing_12" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAdmins"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/spacing_16" />

    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/brand_primary"
        android:textColor="@color/brand_primary" />

</LinearLayout>
