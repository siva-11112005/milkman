<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="@dimen/elevation_small">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_bar_height"
            android:background="@color/error_red"
            app:title="📋 Audit Log"
            app:titleTextColor="@color/brand_on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Info Section -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_12"
        app:cardBackgroundColor="@color/error_container"
        app:cardCornerRadius="@dimen/corner_radius_large"
        app:cardElevation="@dimen/elevation_small">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Latest 200 Audit Entries"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/on_error"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:text="Track all create, update, and delete operations"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/on_error" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Audit Log List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAuditLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/spacing_12"
        android:layout_marginBottom="@dimen/spacing_12"
        android:layout_weight="1"
        android:paddingTop="@dimen/spacing_8" />

</LinearLayout>
