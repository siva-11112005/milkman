<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MilkmanDairy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_container</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSecondaryVariant">@color/brand_secondary_container</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Widget.MaterialButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
    </style>

    <style name="Widget.AppBarStyle" parent="Widget.MaterialComponents.AppBarLayout.Primary">
